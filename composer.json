{
	"name": "digitalastronaut/craft-cookie-banner",
	"description": "A fully customizeable and GDPR compliant cookie banner",
	"type": "craft-plugin",
	"license": "proprietary",
	"support": {
		"email": "bram@digitalastronaut.be",
		"issues": "https://github.com/tim-digitalastronaut/craft-cookie-banner/issues?state=open",
		"source": "https://github.com/tim-digitalastronaut/craft-cookie-banner",
		"docs": "https://github.com/tim-digitalastronaut/craft-cookie-banner",
		"rss": "https://github.com/tim-digitalastronaut/craft-cookie-banner/releases.atom"
	},
	"version": "v1.0.0-beta",
	"require": {
		"php": ">=8.2",
		"craftcms/cms": "^5.8.0",
		"nesbot/carbon": "^2.73",
		"loilo/fuse": "^7.0.0"
	},
	"require-dev": {
		"craftcms/ecs": "dev-main",
		"craftcms/phpstan": "dev-main"
	},
	"autoload": {
		"psr-4": {
			"digitalastronaut\\craftcookiebanner\\": "src/"
		}
	},
	"extra": {
		"handle": "cookie-banner",
		"name": "Cookie banner",
		"developer": "digitalastronaut",
		"documentationUrl": "https://github.com/tim-digitalastronaut/craft-cookie-banner",
		"class": "digitalastronaut\\craftcookiebanner\\CookieBanner"
	},
	"scripts": {
		"check-cs": "ecs check --ansi",
		"fix-cs": "ecs check --ansi --fix",
		"phpstan": "phpstan --memory-limit=1G"
	},
	"config": {
		"sort-packages": true,
		"platform": {
			"php": "8.2"
		},
		"allow-plugins": {
			"yiisoft/yii2-composer": true,
			"craftcms/plugin-installer": true
		}
	}
}
