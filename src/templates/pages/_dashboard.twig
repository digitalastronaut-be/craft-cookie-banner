{% extends "_layouts/cp.twig" %}

{% import '_includes/forms.twig' as forms %}

{% set title = "Dashboard"|t("cookie-banner") %}
{% set selectedSubnavItem = 'dashboard' %}

{% set crumbs = [
    { label: 'Cookie banner'|t("cookie-banner"), url: url('cookie-banner') },
    { label: 'Getting started'|t("cookie-banner"), url: url('cookie-banner/dashboard') },
] %}

{% block content %}
    <div class="ccb-dashboard">
        <div class="ccb-graph">
            <h2>{{ "Consent records from the last 30 days"|t("cookie-banner") }}</h2>

            <div class="ccb-graph-numbers">
                <div class="ccb-graph-number">
                    <h3 class="ccb-typo-body-md ccb-semi-bold">{{ "Total"|t("cookie-banner") }}</h3>

                    <div class="ccb-graph-number-value">
                        <p class="ccb-semi-bold">{{ consentRecordsChart.metrics.total|default(0) }}</p>
                    </div>
                </div>

                <div class="ccb-graph-number">
                    <h3 class="ccb-typo-body-md ccb-semi-bold">{{ "Average/day"|t("cookie-banner") }}</h3>

                    <div class="ccb-graph-number-value">
                        <p class="ccb-semi-bold">{{ consentRecordsChart.metrics.dailyAverage|default(0) }}</p>
                    </div>
                </div>

                <div class="ccb-graph-number">
                    <h3 class="ccb-typo-body-md ccb-semi-bold">{{ "Acceptance rate"|t("cookie-banner") }}</h3>

                    <div class="ccb-graph-number-value">
                        <p class="ccb-semi-bold">{{ consentRecordsChart.metrics.acceptanceRate|default("0") }}%</p>
                    </div>
                </div>
            </div>

            <consent-records-graph 
                data-chart="{{ consentRecordsChart.data|json_encode }}" 
                class="consent-records-graph"
            >
                <canvas id="consent-records-graph"></canvas>
            </consent-records-graph>
        </div>

        <div class="ccb-graph">
            <h2>{{ "Cookies and vendors status"|t("cookie-banner") }}</h2>
        
            <cookies-and-vendors-graph 
                data-cookies="{{ cookiesAndVendorsChart.cookies.data|json_encode }}" 
                data-vendors="{{ cookiesAndVendorsChart.vendors.data|json_encode }}" 
                class="cookies-and-vendors-graph"
            >
                <div class="cookies-and-vendors-graph-container">
                    <canvas id="cookies-graph"></canvas>
                </div>

                <div class="cookies-and-vendors-graph-container">
                    <canvas id="vendors-graph"></canvas>
                </div>
            </cookies-and-vendors-graph>

            {% set colorMap = {
                'Defined': '#10b981',
                'Defined incomplete': '#facc15',
                'Suggested': '#4299E1',
                'Control panel': '#d8e2ee',
            } %}

            <div class="ccb-graph-legend">
                {% for chartKey, chart in cookiesAndVendorsChart %}
                    <div class="ccb-graph-sub-legend">
                        <h3>{{ chartKey|capitalize }}</h3>
                    
                        <ul class="ccb-graph-sub-legend-items">
                            {% for label, count in chart.metrics %}
                                <li class="ccb-graph-legend-item">
                                    <div style="background-color: {{ colorMap[label] }};"></div>
                                    <span>{{ count }} {{ label }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {% if not gettingStartedProgress|filter(isCompleted => not isCompleted)|length == 0 %}
        {% set steps = [
            {
                key: 'legalPagesStepCompleted',
                title: 'Correctly setup your legal pages'|t('cookie-banner'),
                instructions: [
                    'Create the mandatory privacy and cookie policy pages (can be one page)'|t('cookie-banner'),
                    'Link them correctly in <a href="{url}">the cookie banner content tab</a> for each site/language.'|t('cookie-banner', {
                        url: cpUrl('cookie-banner/content')
                    }),
                    'Render a table of all cookies and their purpose on the cookie page. You can easily achieve this using the build in <code>{{ getCookiesTableHtml() }}</code> twig extension'|t('cookie-banner'),
                ],
            },
            {
                key: 'deferScriptsStepCompleted',
                title: 'Defer third party scripts/embeds on the website until consent is given'|t('cookie-banner'),
                instructions: [
                    'Make sure to respect cookie banner consent when using third party tools such as Google Analytics.'|t('cookie-banner'),
                    'Only load embeds/iframe consent if consent is given'|t('cookie-banner'),
                    'When using forms make sure users are aware of what their data is used for and where and how long it stored'|t('cookie-banner'),
                    'Read the guide and most common pitfalls in <a href="#">the documentation</a>'|t('cookie-banner'),
                ],
            },
            {
                key: 'contentStepCompleted',
                title: 'Complete (and translate) the cookie banner content'|t('cookie-banner'),
                instructions: [
                    'Fill out basic content fields: title, description, definitions and button labels'|t('cookie-banner'),
                    'Use <a href="{url}">the compliancy checklist</a> to easily add all your cookies to the banner in multiple languages'|t('cookie-banner', {
                        url: cpUrl('cookie-banner/cookies-and-vendors')
                    }),
                    'Assign vendors to your cookies if you wish'|t('cookie-banner'),
                ],
            },
            {
                key: 'appearanceStepCompleted',
                title: 'Personalise the cookie banner'|t('cookie-banner'),
                instructions: [
                    'Use <a href="{url}">the appearance tab</a> to customize the look and functionality of the banner'|t('cookie-banner', {
                        url: cpUrl('cookie-banner/appearance')
                    }),
                ],
            },
            {
                key: 'finalSettingsStepCompleted',
                title: 'Configure some final settings'|t('cookie-banner'),
                instructions: [
                    '<a href="{url}">Configure</a> a retention policy for your consent records'|t('cookie-banner', {
                        url: cpUrl('cookie-banner/settings')
                    }),
                    'Make sure the banner is enabled and your are done!'|t('cookie-banner'),
                ],
            },
        ] %}

        <hr>

        <div class="ccb-getting-started">
            <div class="ccb-getting-started-main">
                <div class="ccb-getting-started-welcome">
                    <h2>{{ "Thanks for installing this cookie banner plugin!"|t("cookie-banner") }}</h2>

                    <p>{{ "Being compliant is unfortunatly way more work than installing a banner for your website. Luckily with this plugin you are halfway there already. Follow this getting started guide to make your site compliant in no time!"|t("cookie-banner") }}</p>

                    <div>
                        <a href="#" class="btn">{{ "Visit the documentation"|t("cookie-banner") }}</a>

                        <form method="post">
                            {{ csrfInput() }}
                            {{ actionInput('cookie-banner/dashboard/skip-guide') }}
                            {{ redirectInput('cookie-banner/dashboard') }}

                            <button type="submit" class="btn">{{ "Skip this guide"|t("cookie-banner") }}</button>
                        </form>
                    </div>
                </div>

                <ul class="ccb-getting-started-checklist">
                    {% for step in steps %}
                        <li class="ccb-getting-started-checklist-item">
                            <article class="ccb-getting-started-goal {{ gettingStartedProgress[step.key] ? 'completed' : '' }}">
                                <div class="ccb-getting-started-goal-main">
                                    <div class="ccb-getting-started-goal-title">
                                        {{ svg("@digitalastronaut/craftcookiebanner/web/icons/circle-check.svg") }}

                                        <h2>{{ step.title }}</h2>
                                    </div>

                                    <ol>
                                        {% for instruction in step.instructions %}
                                            <li><p>{{ instruction|raw }}</p></li>
                                        {% endfor %}
                                    </ol>
                                </div>

                                <div class="ccb-getting-started-goal-action">
                                    <form method="post">
                                        {{ csrfInput() }}
                                        {{ actionInput('cookie-banner/dashboard/complete-guide-step') }}
                                        {{ redirectInput('cookie-banner/dashboard') }}
                                        <input type="hidden" name="step" value="{{ step.key }}">

                                        <button type="submit" class="btn">{{ "Complete this step"|t("cookie-banner") }}</button>
                                    </form>
                                </div>
                            </article>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}
{% endblock %}
