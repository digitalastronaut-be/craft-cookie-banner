{% extends "_layouts/cp.twig" %}

{% import '_includes/forms.twig' as forms %}

{% set title = "Cookie banner content"|t('cookieBanner') %}
{% set selectedSubnavItem = 'content' %}
{% set fullPageForm = true %}

{% if selectableSites is not defined %}
    {% if siteIds is defined %}
        {% set selectableSites = craft.app.sites.getEditableSites()|filter(s => s.id in siteIds) %}
    {% else %}
        {% set selectableSites = craft.app.sites.getEditableSites() %}
    {% endif %}
{% endif %}

{% if selectedSite is not defined %}
    {% if selectedSiteId is defined %}
        {% set selectedSite = craft.app.sites.getSiteById(selectedSiteId) %}
    {% elseif requestedSite and requestedSite in selectableSites %}
        {% set selectedSite = requestedSite %}
    {% else %}
        {% set selectedSite = selectableSites|length ? selectableSites|first : craft.app.sites.getPrimarySite() %}
    {% endif %}
{% endif %}

{% if selectableSites|length > 1 %}
    {% set crumbs = [
        {
            id: 'site-crumb',
            icon: 'world',
            iconAltText: 'Site'|t('app'),
            label: selectedSite.name|t('site'),
            menu: {
                items: siteMenuItems(selectableSites, selectedSite),
                label: 'Select site'|t('app')
            }
        },
        { label: 'Cookie banner'|t('cookie-banner'), url: url('cookie-banner') },
        { label: 'Content'|t('cookie-banner'), url: url('cookie-banner/content') },
    ] %}
{% else %}
    {% set crumbs = [
        { label: 'Cookie banner'|t('cookie-banner'), url: url('cookie-banner') },
        { label: 'Content'|t('cookie-banner'), url: url('cookie-banner/content') },
    ] %}
{% endif %}

{% set vendors = [{"label": "Default", "value": "default" }]|merge(
    content.vendors|default([])|map(item => {
        'label': item.name,
        'value': item.name|kebab
    })
) %}

{% block content %}
    {{ actionInput('cookie-banner/content/save') }}
    {{ hiddenInput('siteId', selectedSite.id) }}

    <div class="flex-fields ccb-settings">
        <h2>{{ 'Introduction'|t('cookie-banner') }}</h2>

        <div class="field width-50">
            {{ forms.textField({
                label: 'Title'|t('cookie-banner'),
                id: 'title',
                name: 'fields[title]',
                value: content.title ?? '',
                placeholder: 'Title'|t('cookie-banner'),
            }) }}
        </div>

        <div class="field line-break"></div>

        <div class="field width-75">
            {{ forms.textareaField({
                label: 'Text'|t('cookie-banner'),
                id: 'text',
                name: 'fields[text]',
                value: content.text ?? '',
                placeholder: 'Text'|t('cookie-banner'),
                rows: 4,
            }) }}
        </div>

        <div class="line-break"></div>

        <h3 class="ccb-h3-label">{{ 'Privacy policy link'|t('cookie-banner') }}</h3>

        <div class="field width-25">
            {{ forms.textField({
                id: 'privacyPolicyLinkLabel',
                name: 'fields[privacyPolicyLinkLabel]',
                value: content.privacyPolicyLinkLabel ?? '',
                placeholder: 'Label'|t('cookie-banner'),
            }) }}
        </div>

        <div class="field width-50">
            {{ forms.textField({
                id: 'privacyPolicyLinkURL',
                name: 'fields[privacyPolicyLinkURL]',
                value: content.privacyPolicyLinkURL ?? '',
                placeholder: 'URL'|t('cookie-banner'),
            }) }}
        </div>

        <h3 class="ccb-h3-label">{{ 'Cookie policy link'|t('cookie-banner') }}</h3>

        <div class="field width-25">
            {{ forms.textField({
                id: 'cookiePolicyLinkLabel',
                name: 'fields[cookiePolicyLinkLabel]',
                value: content.cookiePolicyLinkLabel ?? '',
                placeholder: 'Label'|t('cookie-banner'),
            }) }}
        </div>

        <div class="field width-50">
            {{ forms.textField({
                id: 'cookiePolicyLinkURL',
                name: 'fields[cookiePolicyLinkURL]',
                value: content.cookiePolicyLinkURL ?? '',
                placeholder: 'URL'|t('cookie-banner'),
            }) }}
        </div>

        <hr>

        <h2>{{ 'Cookies'|t('cookie-banner') }}</h2>

        <div class="field width-75">
            {% if content.vendors|length %}
                {{ forms.editableTableField({
                    label: 'Vendors'|t('cookie-banner'),
                    id: 'vendors',
                    name: 'fields[vendors]',
                    tip: 'Adding or removing vendors can be done via the [cookies & vendors tab](/cookie-banner/cookies-and-vendors)'|t('cookie-banner'),
                    cols: {
                        name: { heading: "Name"|t('cookie-banner'), type: "singleline" },
                        description: { heading: "Description"|t('cookie-banner'), type: "multiline"},
                        url: { heading: "URL"|t('cookie-banner'), type: "url"},
                        enabled: { heading: "Enabled"|t('cookie-banner'), type: "lightswitch"},
                    },
                    rows: content.vendors ?? [],
                    allowReorder: true,
                }) }}
            {% else %}
                <div class="pane no-border zilch small">
                    <p class="zilch small">{{ "No vendors defined"|t('cookie-banner') }}</p>
                </div>    
            {% endif %}
        </div>

