{% extends "_layouts/cp.twig" %}

{% import '_includes/forms.twig' as forms %}

{% set title = "Edit the " ~ cookieForAllSites[0].name ~ " cookie for all sites" %}
{% set selectedSubnavItem = 'compliancyChecklist' %}
{% set fullPageForm = true %}

{% set crumbs = [
    { label: 'Cookie banner'|t, url: url('cookie-banner') },
    { label: 'Compliancy checklist'|t, url: url('cookie-banner/cookies-and-vendors') },
    { label: 'Manually edit cookie'|t },
] %}

{% block content %}
    <div class="ccb-edit-cookie">
        {{ forms.editableTableField({
            id: 'cookieForAllSites',
            name: 'fields[cookieForAllSites]',
            cols: {
                siteName: { 
                    heading: "Site", 
                    type: "singleline",
                    width: '15%',
                },
                name: { 
                    heading: "Cookie Name", 
                    type: "singleline",
                },
                group: { 
                    heading: "Vendor", 
                    type: "select",
                    options: getVendorOptions()
                },
                purpose: { 
                    heading: "Purpose", 
                    type: "multiline",
                },
                expiration: { 
                    heading: "Expiration", 
                    type: "singleline",
                },
                enabled: {
                    heading: "Enabled for this site",
                    type: "lightswitch",
                    width: '10%',
                }
            },
            rows: cookieForAllSites,
            allowAdd: false,
            allowDelete: false,
            allowReorder: false,
            staticRows: true,
        }) }}
    </div>
{% endblock %}